set.seed(1234)
set.seed(1234)
x = rnorm(12,mean=rep(1:3,each=4),sd=0.2)
y = rnorm(12,mean=rep(c(1,2,1),each=4),sd=0.2)
plot(x,y,col="blue",pch=19,cex=1.5)
text(x+0.05,y+0.05,labels=as.character(1:12))
dataFrame <- data.frame(x=x,y=y)
dist(dataFrame)
distxy = dist(dataFrame, method = "euclidean")
hc = hclust(distxy)
plot(hc)
my.plot.hc = function(hclust, lab = 1:length(hclust$order),
lab.col = rep(1, length(hclust$order)),
hang = 0.1, ...)
{
y = rep(hclust$height, 2)
x = as.numeric(hclust$merge)
y = y[which(x<0)]
x = x[which(x<0)]
x = abs(x)
y = y[order(x)]
x = x[order(x)]
plot(hclust, labels = F, hang = hang, ...)
text(x = x, y = y[hclust$order]- (max(hclust$height) * hang),
labels = lab[hclust$order], col = lab.col[hclust$order],
srt = 90, adj = c(1,0.5), xpd = NA, ...)
}
# hierarchical clustering - iris
iris.sc = scale(iris[,1:4])
dist.iris = dist(iris.sc, method = "euclidean")
hc.complete = hclust(dist.iris, method = "complete")
my.plot.hc (hc.complete, lab.col = as.integer(iris$Species)+1, cex = 0.4)
legend("topright", c("Setosa","Versicolor","Virginica"), fill = c("red", "green","blue"), bty = "n", cex = 0.7)
hc.average = hclust(dist.iris, method = "average")
my.plot.hc (hc.average,  lab.col = as.integer(iris$Species)+1, cex = 0.4)
# heatmaps
x1 = rnorm(12,mean=rep(1:3,each=4),sd=0.2)
x2 = rnorm(12,mean=rep(1:3,each=4),sd=0.2)
y1 = rnorm(12,mean=rep(c(1,2,1),each=4),sd=0.2)
y2 = rnorm(12,mean=rep(c(1,2,1),each=4),sd=0.2)
df2 = data.frame(x1, x2, y1, y2)
heatmap(as.matrix(df2))
dist.full = as.matrix(dist.iris, diag = TRUE, upper = TRUE)
heatmap(dist.full, labRow=iris$Species, labCol=iris$Species, cexRow=0.3, cexCol=0.3)
# divisive
library("cluster")
res_diana = diana (distxy)
plot(res_diana)
# clustering hierarquico - cachexia
download.file("http://darwin.di.uminho.pt/dataAnalysisR/cachexia.csv","cachexia.csv")
download.file("http://darwin.di.uminho.pt/dataAnalysisR/meta_cachexia.csv","meta.csv")
cachexia = read.table("cachexia.csv", sep = ",", header = T, row.names = 1)
meta_cachexia = read.table("meta.csv", sep = ",", header = T, row.names = 1)
meta_cachexia$Muscle.loss = as.factor(meta_cachexia$Muscle.loss)
cachexia = cbind(cachexia, meta_cachexia)
dim(cachexia)
cachexia.sc = scale(cachexia[,1:63])
dist.cachexia = dist(cachexia.sc, method = "manhattan")
cl.cachexia = hclust(dist.cachexia, method = "ward.D")
my.plot.hc(cl.cachexia, lab.col = as.integer(cachexia$Muscle.loss)+1, cex = 0.6)
